{
  "name": "ujcms-cp",
  "version": "10.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:starter": "vite build --outDir ../ujcms-starter/src/main/webapp/cp --emptyOutDir",
    "preview": "vite preview",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "lint-staged": "lint-staged",
    "plop": "plop"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.9",
    "@element-plus/icons-vue": "^2.3.1",
    "@toast-ui/chart": "^4.6.1",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-chart": "^3.0.1",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "@toast-ui/editor-plugin-table-merged-cell": "^3.1.0",
    "@toast-ui/editor-plugin-uml": "^3.0.1",
    "@vueuse/components": "^10.11.1",
    "@vueuse/core": "^10.11.1",
    "axios": "^1.7.7",
    "bpmn-js": "^17.11.1",
    "codemirror": "^6.0.1",
    "core-js": "^3.48.0",
    "cropperjs": "^1.6.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "diagram-js": "^14.11.3",
    "diagram-js-direct-editing": "^2.1.2",
    "domutils": "^3.1.0",
    "echarts": "^5.5.1",
    "element-plus": "~2.8.8",
    "entities": "^4.5.0",
    "file-saver": "^2.0.5",
    "htmlparser2": "^9.1.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "min-dash": "^4.2.2",
    "nprogress": "^0.2.0",
    "path-to-regexp": "^6.3.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "prismjs": "^1.29.0",
    "sm-crypto": "^0.3.13",
    "sortablejs": "1.14.0",
    "tinymce": "~5.9.2",
    "vue": "^3.5.28",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.2",
    "vuedraggable": "^4.1.0"
